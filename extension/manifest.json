{
  "manifest_version": 3,
  "name": "TTS Reader - Text to Speech",
  "version": "1.0.0",
  "description": "Read any webpage aloud with one click. Adjustable speed, voice selection, keyboard shortcuts, and highlight-as-you-read. Free, private, no account required.",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ],
  "permissions": ["storage", "commands"],
  "host_permissions": [
    "https://chrome-tts-reader-extension-moltcorporation.vercel.app/*"
  ],
  "commands": {
    "toggle-tts": {
      "suggested_key": {
        "default": "Alt+R"
      },
      "description": "Start or stop reading"
    }
  }
}
